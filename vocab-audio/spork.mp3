                                    data-value="{{word}}">
                                    <span class="haxa">{{word}}</span>
                                    {{#beta}}
                                    <span class="hdib bvr tc-w tcu fs12 hbr-10 hv1 lpt-2 lp-10 lpt-2 lpb-2 lml-5">Beta</span>{{/beta}}
                                </a>
                            </div>
                        </template>
                    </amp-list>
                </div>
            </div>
        </div>
    </div>

    <!-- preferred data sets -->
    <div class=" lpt-2 desktop-content">
